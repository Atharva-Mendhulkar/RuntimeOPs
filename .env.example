# IBM Bob - Environment Configuration Template
# Copy this file to .env and fill in the values

# Environment
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=bobpassword123

# Weaviate Configuration
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=bob
POSTGRES_PASSWORD=bobpassword123
POSTGRES_DB=bob_registry

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=bobpassword123
REDIS_DB=0

# GitHub Configuration
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=

# LLM Configuration
OPENAI_API_KEY=
GEMINI_API_KEY=
LLM_PROVIDER=openai  # openai or gemini
EMBEDDING_MODEL=text-embedding-3-small

# Security
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
ENCRYPTION_KEY=  # Base64 encoded Fernet key

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
GRPC_PORT=50052
API_WORKERS=4
RATE_LIMIT_PER_MINUTE=500
RATE_LIMIT_BURST=1000

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=bob-api
ENABLE_TRACING=true
ENABLE_METRICS=true

# Indexing Configuration
MAX_CONCURRENT_INDEXING_JOBS=5
INDEXING_TIMEOUT_SECONDS=600
INCREMENTAL_UPDATE_TIMEOUT_SECONDS=60
MAX_REPO_SIZE_KLOC=500

# Query Configuration
QUERY_TIMEOUT_SECONDS=10
SEMANTIC_SEARCH_DEFAULT_K=10
MAX_GRAPH_TRAVERSAL_HOPS=5
CACHE_TTL_SECONDS=300

# Performance
FILE_CACHE_TTL_SECONDS=3600
CONVENTION_CACHE_TTL_SECONDS=86400
QUERY_RESULT_CACHE_TTL_SECONDS=300